<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.ud_quizzi.view.TakingExamController"
            prefWidth="900" prefHeight="600">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #ecf0f1; -fx-padding: 15; -fx-border-color: #bdc3c7; -fx-border-width: 0 0 1 0;">
            <Label fx:id="lblExamTitle" text="Tên Bài Thi" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Thời gian còn lại: " style="-fx-font-size: 16px;"/>
            <Label fx:id="lblTimer" text="00:00" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold; -fx-font-size: 22px;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding: 30;">
            <Label fx:id="lblQuestionNumber" text="Câu 1:" style="-fx-font-weight: bold; -fx-text-fill: #2980b9; -fx-font-size: 18px;"/>

            <Label fx:id="lblQuestionContent" text="Nội dung câu hỏi sẽ hiển thị ở đây..." wrapText="true"
                   style="-fx-font-size: 18px; -fx-background-color: #ffffff; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #bdc3c7; -fx-border-radius: 10;"/>

            <VBox spacing="15" style="-fx-padding: 10 0 0 20;">
                <RadioButton fx:id="radA" text="A. Option A" style="-fx-font-size: 16px;"/>
                <RadioButton fx:id="radB" text="B. Option B" style="-fx-font-size: 16px;"/>
                <RadioButton fx:id="radC" text="C. Option C" style="-fx-font-size: 16px;"/>
                <RadioButton fx:id="radD" text="D. Option D" style="-fx-font-size: 16px;"/>
            </VBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="50" style="-fx-padding: 20; -fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7; -fx-border-width: 1 0 0 0;">
            <Button fx:id="btnPrev" text="⬅ Câu trước" onAction="#handlePrev" prefWidth="120" style="-fx-font-size: 14px;"/>

            <Button text="NỘP BÀI" onAction="#handleSubmit"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 5;"
                    prefWidth="150" prefHeight="40"/>

            <Button fx:id="btnNext" text="Câu sau ➡" onAction="#handleNext" prefWidth="120" style="-fx-font-size: 14px;"/>
        </HBox>
    </bottom>

</BorderPane>